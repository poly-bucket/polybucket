      "SecretKey": "",
      "Region": "us-east-1",
      "MaxFileSize": 1073741824,
      "AllowedExtensions": [".stl", ".obj", ".fbx", ".3ds", ".glb", ".gltf", ".ply", ".step", ".stp", ".iges", ".igs", ".brep", ".png", ".jpg", ".jpeg", ".gif"]
