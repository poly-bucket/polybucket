{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=polybucket;Username=postgres;Password=postgres;"
  },
  "Database": {
    "EnsureDatabaseCreated": true,
    "MaintenanceDatabase": "postgres",
    "SkipHostDatabaseInitialization": false
  },
  "Admin": {
    "Username": "admin",
    "Email": "admin@polybucket.app",
    "Password": "Polybucket123!"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "PolyBucket.Api": "Debug"
    }
  },
  "JwtSettings": {
    "Secret": "development-secret-key-replace-with-long-random-string-in-production"
  },
  "Storage": {
    "Endpoint": "minio",
    "ExternalEndpoint": "localhost",
    "Port": 9000,
    "ExternalPort": 9000,
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "polybucket-uploads",
    "UseSSL": false,
    "ExternalUseSSL": false
  },
  "EmailSettings": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "UserName": "",
    "Password": ""
  },
  "OpenTelemetry": {
    "ServiceName": "polybucket-api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableAspNetCoreInstrumentation": true,
    "EnableEntityFrameworkCoreInstrumentation": true,
    "SamplingRate": 1.0
  },
  "AppSettings": {
    "Security": {
      "JwtSecret": "development-secret-key-replace-with-long-random-string-in-production-minimum-32-chars",
      "JwtIssuer": "polybucket-api",
      "JwtAudience": "polybucket-frontend",
      "AccessTokenExpiryMinutes": 1440,
      "RefreshTokenExpiryDays": 30,
      "MaxFailedAccessAttempts": 5,
      "LockoutDurationMinutes": 15
    },
    "Email": {
      "EnableEmailVerification": false,
      "RequireEmailVerification": false,
      "SmtpServer": "smtp.example.com",
      "SmtpPort": 587,
      "SmtpUsername": "user@example.com",
      "SmtpPassword": "password",
      "UseSsl": true,
      "FromEmail": "noreply@polybucket.com",
      "FromName": "PolyBucket"
    },
    "Frontend": {
      "BaseUrl": "http://localhost:3001"
    },
    "Storage": {
      "BasePath": "uploads",
      "MaxFileSize": 1073741824,
      "AllowedExtensions": [".stl", ".obj", ".fbx", ".3ds", ".glb", ".gltf", ".ply", ".step", ".stp", ".iges", ".igs", ".brep", ".png", ".jpg", ".jpeg", ".gif"]
    }
  }
}
