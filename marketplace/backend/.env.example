# Marketplace Backend Environment Variables
#
# For local development, the backend reads from:
# - appsettings.json
# - appsettings.Development.json
# - Environment variables
#
# However, for simplicity with Docker Compose, we recommend using the root .env file
# which is automatically loaded by docker-compose.yml
#
# OR manually create .env with just the backend variables if running locally:
#
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://+:10280
# ConnectionStrings__DefaultConnection=Host=localhost;Database=polybucket_marketplace;Username=polybucket;Password=password
# Jwt__SecretKey=your-super-secret-jwt-key-here-change-in-production-min-32-chars
# Jwt__Issuer=PolyBucket.Marketplace.Api
# Jwt__Audience=PolyBucket.Marketplace.Client
# Jwt__ExpiryMinutes=60
# GitHub__ClientId=your-github-client-id-here
# GitHub__ClientSecret=your-github-client-secret-here
# GitHub__RedirectUri=http://localhost:10110/auth/callback
# FileStorage__UploadPath=uploads/plugins

# See ../.env.example for the complete list of all environment variables
