{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=polybucket-db;Port=5432;Database=polybucket_marketplace;Username=postgres;Password=postgres"
  },
  "FileStorage": {
    "UploadPath": "uploads/plugins"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-jwt-key-here-change-in-production",
    "Issuer": "PolyBucket.Marketplace.Api",
    "Audience": "PolyBucket.Marketplace.Client",
    "ExpiryMinutes": 60
  },
  "GitHub": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/marketplace-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "EnableSwagger": true
}