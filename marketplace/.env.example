# ==============================================================================
# Marketplace Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your actual values
# This file contains ALL environment variables for both frontend and backend
#
# Usage:
#   - Docker Compose: Automatically loads from .env file
#   - Local Development: Copy to frontend/.env.local and backend/.env as needed
# ==============================================================================

# ==============================================================================
# FRONTEND Environment Variables (NEXT_PUBLIC_ prefix)
# ==============================================================================
# These variables are exposed to the browser and embedded in the JavaScript bundle
# Next.js automatically loads these from .env.local, .env.development, etc.

# API URL for the marketplace backend
NEXT_PUBLIC_API_URL=http://localhost:10120

# Main PolyBucket application URL
NEXT_PUBLIC_POLYBUCKET_URL=http://localhost:3000

# GitHub OAuth Configuration (Frontend)
# Get these from: https://github.com/settings/developers
# 
# Steps to create GitHub OAuth App:
# 1. Go to GitHub Settings > Developer settings > OAuth Apps
# 2. Click "New OAuth App"
# 3. Fill in:
#    - Application name: PolyBucket Marketplace
#    - Homepage URL: http://localhost:10110
#    - Authorization callback URL: http://localhost:10110/auth/callback
# 4. Copy the Client ID and create a Client Secret
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id-here
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://localhost:10110/auth/callback

# ==============================================================================
# BACKEND Environment Variables (Server-side only)
# ==============================================================================
# These are NOT exposed to the browser

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:10280

# Database Connection Configuration
# Individual connection string components (for docker-compose)
MARKETPLACE_DB_HOST=localhost
MARKETPLACE_DB_PORT=5433
MARKETPLACE_DB_NAME=polybucket_marketplace
MARKETPLACE_DB_USER=postgres
MARKETPLACE_DB_PASSWORD=postgres

# Database Connection String (constructed from above or set directly)
# Format: Host=hostname;Port=port;Database=database;Username=user;Password=password
# If not set, will be constructed from MARKETPLACE_DB_* variables above
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=polybucket_marketplace;Username=postgres;Password=postgres

# JWT Authentication
# IMPORTANT: Use a strong, random secret key in production (minimum 32 characters)
# Generate one using: openssl rand -base64 32
Jwt__SecretKey=your-super-secret-jwt-key-here-change-in-production-min-32-chars
Jwt__Issuer=PolyBucket.Marketplace.Api
Jwt__Audience=PolyBucket.Marketplace.Client
Jwt__ExpiryMinutes=60

# GitHub OAuth (Backend)
# These values are used by the backend to exchange the OAuth code for tokens
# The Client ID should match NEXT_PUBLIC_GITHUB_CLIENT_ID above
GitHub__ClientId=your-github-client-id-here
GitHub__ClientSecret=your-github-client-secret-here
GitHub__RedirectUri=http://localhost:10110/auth/callback

# Alternative: Environment variables can also be set directly (for Docker/System)
# GITHUB_CLIENT_ID=your-github-client-id-here
# GITHUB_CLIENT_SECRET=your-github-client-secret-here
# GITHUB_REDIRECT_URI=http://localhost:10110/auth/callback

# File Storage Configuration
FileStorage__UploadPath=uploads/plugins

# ==============================================================================
# Docker Compose Variables (Optional)
# ==============================================================================
# These are used by docker-compose.yml when needed

# Database configuration for docker-compose
POSTGRES_DB=polybucket_marketplace
POSTGRES_USER=polybucket
POSTGRES_PASSWORD=password

# Redis configuration (if used)
REDIS_PASSWORD=
